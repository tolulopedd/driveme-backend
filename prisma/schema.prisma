generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING_APPROVAL
  DISABLED
}

enum DriverApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  ENROUTE
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TripStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  RECORDED
  FAILED
  REFUNDED
}

enum NotificationType {
  BOOKING_SUBMITTED
  DRIVER_ACCEPTED
  DRIVER_ARRIVED
  TRIP_STARTED
  TRIP_COMPLETED
  UPCOMING_TRIP
  APPLICATION_REVIEWED
}

enum NotificationChannel {
  PUSH
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  READ
}

enum BookingDispatchStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ContactMessageStatus {
  NEW
  RESOLVED
}

enum EmailVerificationPurpose {
  CUSTOMER_SIGNUP
  DRIVER_ONBOARDING
}

enum DocumentType {
  DRIVER_LICENSE
  ID_CARD
  PASSPORT_PHOTO
  BACKGROUND_CHECK
  OTHER
}

model User {
  id              String           @id @default(uuid())
  fullName        String
  email           String           @unique
  phone           String?
  passwordHash    String
  role            UserRole
  status          AccountStatus    @default(ACTIVE)
  emailVerifiedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  customerProfile CustomerProfile?
  driver          Driver?
  adminUser       AdminUser?
  refreshTokens   RefreshToken[]
  notifications   Notification[]
  applications    DriverApplication[]
  ratingsWritten  Rating[]         @relation("RatingReviewer")
  ratingsReceived Rating[]         @relation("RatingReviewed")
  auditLogs       AuditLog[]       @relation("AuditActor")
  reviewedApplications DriverApplication[] @relation("ApplicationReviewer")
}

model EmailVerificationToken {
  id        String                   @id @default(uuid())
  email     String
  purpose   EmailVerificationPurpose
  tokenHash String                   @unique
  payload   Json?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@index([email, purpose])
  @@index([expiresAt])
}

model CustomerProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  savedAddresses String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]
  bookings Booking[]
}

model Driver {
  id                   String    @id @default(uuid())
  userId               String    @unique
  applicationId        String?   @unique
  licenseNumber        String
  yearsOfExperience    Int
  emergencyContact     String
  serviceAreas         String[]
  availabilitySchedule String?
  availabilityStatus   Boolean   @default(false)
  approvedAt           DateTime?
  currentLatitude      Float?
  currentLongitude     Float?
  locationUpdatedAt    DateTime?
  currentZoneId        String?
  earningsAmount       Float     @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  application     DriverApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  currentZone     ServiceZone?       @relation(fields: [currentZoneId], references: [id], onDelete: SetNull)
  bookings        Booking[]
  trips           Trip[]
  bookingDispatches BookingDispatch[]
  documents       Document[]
  locationUpdates Location[]
}

model AdminUser {
  id          String   @id @default(uuid())
  userId      String   @unique
  title       String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverApplication {
  id                    String                  @id @default(uuid())
  userId                String                  @unique
  fullName              String
  phone                 String
  email                 String
  address               String
  licenseNumber         String
  yearsOfExperience     Int
  emergencyContact      String
  preferredServiceAreas String[]
  availabilitySchedule  String?
  status                DriverApplicationStatus @default(SUBMITTED)
  reviewNote            String?
  reviewedByUserId      String?
  reviewedAt            DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("ApplicationReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  documents  Document[]
  driver     Driver?
}

model Vehicle {
  id          String   @id @default(uuid())
  customerId  String
  make        String
  model       String
  plateNumber String
  color       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Booking {
  id                      String        @id @default(uuid())
  customerId              String
  vehicleId               String?
  assignedDriverId        String?
  pickupLocation          String
  pickupLat               Float
  pickupLng               Float
  destinationLocation     String
  destinationLat          Float
  destinationLng          Float
  scheduledStartAt        DateTime
  expectedDurationMinutes Int
  specialNotes            String?
  vehicleDetails          String?
  fareEstimate            Float
  zoneCode                String
  activationWindowStartAt DateTime
  activationWindowEndAt   DateTime
  status                  BookingStatus @default(PENDING)
  acceptedAt              DateTime?
  completedAt             DateTime?
  cancelledAt             DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  customer        CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle         Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  assignedDriver  Driver?         @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  trip            Trip?
  payment         Payment?
  rating          Rating?
  dispatches      BookingDispatch[]
  locationUpdates Location[]

  @@index([status, scheduledStartAt])
  @@index([assignedDriverId, status])
  @@index([customerId, scheduledStartAt])
}

model BookingDispatch {
  id         String               @id @default(uuid())
  bookingId  String
  driverId   String
  distanceKm Float?
  status     BookingDispatchStatus @default(PENDING)
  notifiedAt DateTime             @default(now())
  respondedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([bookingId, driverId])
  @@index([driverId, status])
  @@index([bookingId, status])
}

model Trip {
  id                 String     @id @default(uuid())
  bookingId          String     @unique
  driverId           String
  status             TripStatus @default(SCHEDULED)
  startedAt          DateTime?
  endedAt            DateTime?
  navigationEnabled  Boolean    @default(false)
  liveTrackingEnabled Boolean   @default(false)
  routePolyline      Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model Location {
  id         String   @id @default(uuid())
  bookingId  String
  driverId   String?
  latitude   Float
  longitude  Float
  heading    Float?
  speedKph   Float?
  source     String   @default("mobile")
  recordedAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([bookingId, recordedAt])
}

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique
  amount            Float
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  providerReference String?
  recordedAt        DateTime?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  channel   NotificationChannel
  status    NotificationStatus @default(PENDING)
  meta      Json?
  createdAt DateTime           @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Rating {
  id             String   @id @default(uuid())
  bookingId      String   @unique
  reviewerId     String
  reviewedUserId String
  score          Int
  comment        String?
  createdAt      DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer  User    @relation("RatingReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewed  User    @relation("RatingReviewed", fields: [reviewedUserId], references: [id], onDelete: Cascade)
}

model Document {
  id            String       @id @default(uuid())
  applicationId String?
  driverId      String?
  type          DocumentType
  fileName      String
  fileUrl       String
  mimeType      String?
  createdAt     DateTime     @default(now())

  application DriverApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  driver      Driver?            @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model ServiceZone {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  centerLat Float
  centerLng Float
  radiusKm  Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  drivers Driver[]
}

model PricingSetting {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  value       Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, createdAt])
}

model ContactMessage {
  id               String               @id @default(uuid())
  fullName         String
  email            String
  province         String?
  subject          String?
  message          String
  source           String               @default("website")
  status           ContactMessageStatus @default(NEW)
  resolvedAt       DateTime?
  resolvedByUserId String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([status, createdAt])
}
